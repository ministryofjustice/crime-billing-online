.govuk-summary-card.custom-summary-card
  .govuk-summary-card__title-wrapper
    %h2.govuk-summary-card__title
      = t("shared.summary.expenses.index.header_#{vat ? 'with_vat' : 'without_vat'}")
  .govuk-summary-card__content
    %dl.govuk-summary-list
      %div.govuk-summary-list__header
        -# %div.govuk-summary-list__row
        %table
          = govuk_table_caption(class: 'govuk-visually-hidden') do
            = t('shared.summary.expenses.index.caption')

          %thead
            %tr
              %th.govuk-table__header
                = t('shared.summary.expenses.index.expense_type')
              %th.govuk-table__header
                = t('shared.summary.expenses.index.reason')
              %th.govuk-table__header{ colspan: 2}
                = t('shared.summary.expenses.index.details')
              %th.govuk-table__header
                = t('shared.summary.expenses.index.date')
              %th.govuk-table__header.govuk-table__header--numeric
                = t('shared.summary.expenses.index.net_amount')
              - if vat
                %th.govuk-table__header.govuk-table__header--numeric
                  = t('shared.summary.expenses.index.vat')
              %th.govuk-table__header.govuk-table__header--numeric
                = t('shared.summary.expenses.index.gross_amount')

          %tbody
            - expenses = vat ? claim.expenses.includes(:expense_type).with_vat : claim.expenses.includes(:expense_type).without_vat
            - present_collection(expenses).each do |expense|
              = render template: 'shared/summary/expenses/new_show', locals: { claim: claim, expense: expense }

          %tfoot
            %tr
              = govuk_table_th(scope: 'row', colspan: 5, 'data-label': t('shared.summary.expenses.expense_type'), class: 'no-bottom-border') do
                = succeed ':' do
                  = t("shared.summary.expenses.index.totals_#{vat ? 'with_vat' : 'without_vat'}")
              = govuk_table_td_numeric('data-label': t('shared.summary.expenses.net_amount'), class: 'no-bottom-border') do
                = vat ? claim.expenses_with_vat_net : claim.expenses_without_vat_net
              - if vat
                = govuk_table_td_numeric('data-label': t('shared.summary.expenses.vat'), class: 'no-bottom-border') do
                  = claim.expenses_vat
              = govuk_table_td_numeric('data-label': t('shared.summary.expenses.gross_amount'), class: 'no-bottom-border') do
                = vat ? claim.expenses_with_vat_gross : claim.expenses_without_vat_gross
